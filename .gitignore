.DS_Store

# Terraform
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.backup
# Include environment-specific tfvars files
!terraform/terraform.tfvars.*
# But exclude personal/secret tfvars
**/*.tfvars.personal
**/*.tfvars.secret
**/*.tfvars.json
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json
**/.terraformrc
**/terraform.rc
**/crash.log
**/crash.*.log
**/*.tfplan
**/*.tfplan.*

# LocalStack
/tmp/localstack/

# Lambda deployment packages
**/*.zip

# Lambda layer build artifacts
lambda/layer/build/

# Python cache files
**/__pycache__/
**/*.pyc

# Claude context
.claude/
